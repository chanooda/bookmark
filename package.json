{
  "name": "bookmark",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ext": "vite build --mode extension && rm -f mark-extension.zip && cd dist && zip -rq ../mark-extension.zip . && cd ..",
    "preview": "vite preview",
    "check": "biome check --write --unsafe --max-diagnostics=none",
    "format": "biome format --write",
    "lint": "biome lint --write --unsafe --max-diagnostics=none",
    "check-types": "tsc --noEmit",
    "install-components": "pnpm dlx shadcn@latest add --all",
    "apply": "pnpm dlx shadcn@latest apply --preset",
    "update-packages": "npx npm-check-updates -u"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@chanooda/libs": "latest",
    "@chanooda/libs-react": "latest",
    "@dnd-kit/react": "^0.4.0",
    "@lukemorales/query-key-factory": "^1.3.4",
    "@tanstack/react-query": "^5.100.5",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.11.0",
    "next-themes": "^0.4.6",
    "overlay-kit": "^1.9.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-i18next": "^17.0.8",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.1",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@chanooda/biome-config-frontend": "latest",
    "@chanooda/typescript-config-frontend": "latest",
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "^0.1.40",
    "@types/node": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.4",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  }
